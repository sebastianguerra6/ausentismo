# Copy this file to ".streamlit/secrets.toml" and set your values.
# Windows Authentication (Trusted Connection) is used, so no user/password here.

[sqlserver]
server = "SQLPRD01"          # e.g. "SQLPRD01" or "SQLPRD01\\INSTANCE"
database = "Bogota_GBS_NS"

[auth]
# Active Directory group whose members are allowed to write to the database.
# Membership is checked with SQL Server IS_MEMBER over the trusted connection.
write_group = "DOMAIN\\YourWriteGroup"
