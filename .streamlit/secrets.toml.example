# Copy this file to ".streamlit/secrets.toml" and set your values.
# SQL access uses Trusted Connection as the Windows service account
# that runs Streamlit (not individual end-user Windows logins).

[sqlserver]
server = "SQLPRD01"          # e.g. "SQLPRD01" or "SQLPRD01\\INSTANCE"
database = "Bogota_GBS_NS"
